# Copy to .env (git-ignored) and adjust. NAMES ONLY here — no real secrets.
# The service runs correctly with ALL of these unset (rules-only path).

# --- Networking ---
HOST=0.0.0.0
PORT=8000

# --- Optional local ML fallback classifier ---
# Set to false to run strictly rules-only (no scikit-learn needed at runtime).
USE_ML_FALLBACK=true
# ML_MODEL_PATH=  # defaults to the packaged artifact
ML_CONFIDENCE_THRESHOLD=0.45

# --- Performance / scaling ---
CACHE_SIZE=2048
MAX_BODY_BYTES=262144
# Gunicorn worker processes (defaults to CPU count). Tune for your host.
WEB_CONCURRENCY=4

# --- Observability ---
LOG_LEVEL=INFO

# NOTE: This project uses NO third-party LLM keys in the judged path. If you
# later add an optional cloud LLM, put its key name here (value stays empty).
